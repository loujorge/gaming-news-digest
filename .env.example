# Provider de notificação: "telegram", "twilio" ou "evolution"
NOTIFICATION_PROVIDER=telegram

# Telegram (recomendado)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=-1001234567890

# Claude Haiku (opcional - para sumarização com IA)
ANTHROPIC_API_KEY=sk-ant-...
SUMMARIZE=false

# Twilio (alternativa WhatsApp)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM=whatsapp:+14155238886
TWILIO_TO=whatsapp:+5511999999999

# Evolution API (alternativa WhatsApp, experimental)
EVOLUTION_API_URL=https://seu-servidor.com
EVOLUTION_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EVOLUTION_INSTANCE=gaming-digest
EVOLUTION_TO=5511999999999@s.whatsapp.net

# Configurações
DEDUPE_THRESHOLD=85
MAX_ARTICLES_PER_SOURCE=5
LOG_LEVEL=INFO
